# ratctl — allow logged-in user access to hidraw and evdev devices
# Install: sudo cp 99-ratctl.rules /etc/udev/rules.d/ && sudo udevadm control --reload-rules && sudo udevadm trigger

# --- ASUS ROG Spatha X ---
SUBSYSTEM=="hidraw", DRIVERS=="usb", ATTRS{idVendor}=="0b05", ATTRS{idProduct}=="1977", MODE="0660", GROUP="input", TAG+="uaccess"
SUBSYSTEM=="hidraw", DRIVERS=="usb", ATTRS{idVendor}=="0b05", ATTRS{idProduct}=="1979", MODE="0660", GROUP="input", TAG+="uaccess"
SUBSYSTEM=="input", DRIVERS=="usb", ATTRS{idVendor}=="0b05", ATTRS{idProduct}=="1977", MODE="0660", GROUP="input", TAG+="uaccess"
SUBSYSTEM=="input", DRIVERS=="usb", ATTRS{idVendor}=="0b05", ATTRS{idProduct}=="1979", MODE="0660", GROUP="input", TAG+="uaccess"

# --- Razer DeathAdder V2 ---
SUBSYSTEM=="hidraw", DRIVERS=="usb", ATTRS{idVendor}=="1532", ATTRS{idProduct}=="0084", MODE="0660", GROUP="input", TAG+="uaccess"
SUBSYSTEM=="input", DRIVERS=="usb", ATTRS{idVendor}=="1532", ATTRS{idProduct}=="0084", MODE="0660", GROUP="input", TAG+="uaccess"

# --- Corsair Scimitar RGB Elite ---
SUBSYSTEM=="hidraw", DRIVERS=="usb", ATTRS{idVendor}=="1b1c", ATTRS{idProduct}=="1b8b", MODE="0660", GROUP="input", TAG+="uaccess"
SUBSYSTEM=="input", DRIVERS=="usb", ATTRS{idVendor}=="1b1c", ATTRS{idProduct}=="1b8b", MODE="0660", GROUP="input", TAG+="uaccess"
